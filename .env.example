# ---- required ----
TONTINE_EMAIL=you@example.com
TONTINE_PASSWORD=your_password_here

# ---- strongly recommended ----
# Discord webhook for the channel you want confirmations/diagnostics in (e.g. an #tontine channel on Asgard).
# Channel settings -> Integrations -> Webhooks -> New Webhook -> Copy URL.
# Change this value (and restart) to retarget a different channel.
DISCORD_WEBHOOK_URL=

# ---- scheduling (all optional; shown with defaults) ----
ATTEMPTS_PER_DAY=12         # number of randomized tries spread across the window
WINDOW_HOURS=12             # window = first N hours of the Eastern day (00:00–12:00 ET by default)
ATTEMPT_ON_START=true       # also fire one attempt immediately when the container starts
OVERTIME=true               # if the window ends unsecured, keep retrying until just before midnight
OVERTIME_INTERVAL_MIN=20    # overtime cadence
OVERTIME_JITTER_MIN=8       # +/- jitter on the overtime cadence
OVERTIME_STOP_HOUR=23       # stop overtime at HH:MM ET (leave headroom before the midnight deadline)
OVERTIME_STOP_MINUTE=45

# ---- notifications ----
ERROR_RENOTIFY_HOURS=3      # suppress identical errors to Discord for this many hours
NOTIFY_MISSED_DAY=true      # red alert if a whole day ends with no successful check-in

# ---- health endpoint + dashboard feed (Unraid badge, Homarr/Homepage) ----
HEALTH_PORT=8080            # serves /health (200/503) and /status (JSON)
HEALTH_STALE_MS=120000      # /health returns 503 if no heartbeat within this many ms

# ---- game stats watch (alive/safe) ----
WATCH_STATS=true            # alert on alive drops (purges) and safe going 0->>0 (check-ins live)
STATS_POLL_MIN=15           # how often (minutes) to poll the stats endpoint
# STATS_URL=https://tontine-stats.s3.us-east-1.amazonaws.com/stats.json

# ---- advanced / rarely needed ----
TZ_NAME=America/New_York
ROTATE_TOKEN=false          # mirror the app's getNewToken step before stayAlive
ATTEMPT_TIMEOUT_MS=120000   # abort a single attempt if it hangs longer than this
DEBUG=false                 # verbose JSON logging of every attempt
# TONTINE_API=https://uodh02r6ni.execute-api.us-east-1.amazonaws.com/prod
# RECAPTCHA_SITE_KEY=6LdgVmwdAAAAALyRxAIZLSh_d8gySMXw_Y18b-8X
